<CycloneDDS>
  <Domain>
    <General>
      <Interfaces>
        <NetworkInterface name="eth0" multicast="true" priority="default"/>
      </Interfaces>
      <AllowMulticast>true</AllowMulticast>
      <MaxMessageSize>65500B</MaxMessageSize>
    </General>

    <Discovery>
      <ParticipantIndex>auto</ParticipantIndex>
      <MaxAutoParticipantIndex>50</MaxAutoParticipantIndex>
      <!--
        No static peer list needed.
        Multicast discovery handles all laptops dynamically.
        Only add a Peer entry if multicast is confirmed broken on your network.
      -->
      <MulticastReceiveSet>
        <Address>239.255.0.1</Address>
      </MulticastReceiveSet>
    </Discovery>

    <Internal>
      <Watermarks>
        <WhcHigh>4MB</WhcHigh>
        <WhcLow>1MB</WhcLow>
      </Watermarks>
    </Internal>
  </Domain>
</CycloneDDS>