<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>perseus_lights</name>
  <version>0.0.0</version>
  <description>Control the light ring via CAN. This is the driver allowing other nodes to control the lights with a /status topic</description>
  <maintainer email="jdbretherton12@gmail.com">Dan Bretherton</maintainer>
  <license>MIT</license>

  <buildtool_depend>ament_cmake</buildtool_depend>

  <depend>rclcpp</depend>
  <depend>std_msgs</depend>
  <depend>hi_can_raw</depend>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
