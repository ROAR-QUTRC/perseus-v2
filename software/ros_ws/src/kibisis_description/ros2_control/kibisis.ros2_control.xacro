<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:macro name="kibisis_ros2_control" params="name prefix hardware_plugin">
    <ros2_control name="${name}" type="system">
      <hardware>
        <plugin>${hardware_plugin}</plugin>
      </hardware>

      <!-- Drive wheel joints -->
      <joint name="${prefix}left_wheel_joint">
        <command_interface name="velocity"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <joint name="${prefix}right_wheel_joint">
        <command_interface name="velocity"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <!--
        Space motor GPIO command interface.
        kibisis_sensors node writes to space_motor/velocity (-100..100).
        Forwarded via space_motor_controller (ForwardCommandController).
      -->
      <gpio name="space_motor">
        <command_interface name="velocity"/>
      </gpio>

      <!--
        Moisture sensor GPIO interfaces.
        kibisis_sensors node writes 1.0 to moisture_sensor/trigger to sample.
        kibisis_sensors node reads moisture_sensor/adc_raw (0-4095) for result.
      -->
      <gpio name="moisture_sensor">
        <command_interface name="trigger"/>
        <state_interface name="adc_raw"/>
      </gpio>

      <!--
        LDR sensor GPIO interfaces.
        kibisis_sensors node writes 1.0 to ldr_sensor/trigger to sample.
        Four state interfaces return ambient and illuminated readings for
        LDR A and LDR B (0-4095 each).
      -->
      <gpio name="ldr_sensor">
        <command_interface name="trigger"/>
        <state_interface name="a_ambient"/>
        <state_interface name="b_ambient"/>
        <state_interface name="a_illuminated"/>
        <state_interface name="b_illuminated"/>
      </gpio>

    </ros2_control>
  </xacro:macro>
</robot>
