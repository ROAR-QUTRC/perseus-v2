diff --git a/lib/karto_sdk/src/cuda/CudaMemoryManager.cu b/lib/karto_sdk/src/cuda/CudaMemoryManager.cu
--- a/lib/karto_sdk/src/cuda/CudaMemoryManager.cu
+++ b/lib/karto_sdk/src/cuda/CudaMemoryManager.cu
