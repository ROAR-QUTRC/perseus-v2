<?xml version="1.0" encoding="UTF-8" ?>
<CycloneDDS xmlns="https://cdds.io/config" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://cdds.io/config https://raw.githubusercontent.com/eclipse-cyclonedds/cyclonedds/master/etc/cyclonedds.xsd">
    <Domain Id="0"> <!--Autonomy ROS domain -->
        <Compatibility>
            <!-- <ManySocketsMode>true</ManySocketsMode> -->
        </Compatibility>
        <Discovery>
            <Peers>
                <!-- All static IPs that should be able to access the autonomy ROS domain -->
                <Peer Address="192.168.1.11"/>
                <Peer Address="192.168.1.12"/>
            </Peers>
            <ParticipantIndex>auto</ParticipantIndex>
            <!-- This setting shouldn't be used when multicast is off, but just in case -->
            <SPDPInterval>20s</SPDPInterval>
        </Discovery>
        <General>
            <AllowMulticast>false</AllowMulticast>
        </General>
    </Domain>
    <Domain Id="2">
        <Discovery>
            <SPDPInterval>20s</SPDPInterval>
        </Discovery>
    </Domain>
</CycloneDDS>
