<CycloneDDS>
  <Domain>
    <General>
      <!-- Avoid broadcasting data to all client  -->
      <AllowMulticast>false</AllowMulticast> 
    </General>

    <Discovery>
      <Peers>
        <!-- Robot PC -->
        <!-- qutrc@big-brain IP -->
        <Peer address="192.168.1.11"/> 
        <!-- qutrc@medium-brain IP -->
        <Peer address="192.168.1.12"/>
        <!-- qutrc@small-brain IP -->
        <Peer address="192.168.1.13"/>

        <!-- Base Station -->
        <Peer address="192.168.0.20"/> 
        <Peer address="192.168.0.20"/>
      </Peers>
    </Discovery>
  </Domain>
</CycloneDDS>
